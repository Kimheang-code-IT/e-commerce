# Copy this file to `.env` in the same folder (`Backend/.env`) and set real values.
# Never commit `.env` (it is gitignored).

# Required for production: long random string (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-secret

# JWT lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite (default). For PostgreSQL later you can switch engine code and use DATABASE_URL-style vars.
SQLITE_URL=sqlite:///./app.db

# API metadata
APP_NAME=E-Commerce Backend API
API_PREFIX=/api/v1

# Comma-separated browser origins allowed for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public base URL of this API (used for `/uploads/...` links returned to the frontend)
FILE_BASE_URL=http://127.0.0.1:8000

# Export JSON spill threshold / folder name (relative to cwd when exporting)
EXPORT_INLINE_THRESHOLD=100
EXPORT_DIR=exports
